rules_version = '2';

// Leaderboard rules.
// - Anyone can read (public ranking).
// - Anyone can create a score, but only if it is well-formed AND internally
//   consistent (score can't exceed what the claimed line count allows).
// - No one can edit or delete from the client. Moderation is done manually
//   in the Firebase console (deleting a document = losing the leaderboard spot).
//
// The consistency check below blocks casual cheating: posted data must look
// like a result the game could actually produce. App Check can be added later
// as a second layer if real abuse shows up.

service cloud.firestore {
  match /databases/{database}/documents {
    match /scores/{id} {
      allow read: if true;
      allow create: if isValidScore(request.resource.data);
      allow update, delete: if false;
    }

    function isValidScore(d) {
      return d.keys().hasOnly(['nick', 'country', 'comment', 'score', 'lines', 'rounds', 'createdAt'])
        && d.nick is string && d.nick.size() >= 1 && d.nick.size() <= 20
        && d.country is string && d.country.matches('[A-Z]{2}')
        && d.comment is string && d.comment.size() <= 140
        && d.score is int && d.score >= 0
        && d.lines is int && d.lines >= 0 && d.lines <= 600
        && d.rounds is int && d.rounds >= 1 && d.rounds <= 10
        // Consistency: max points per line = speed 10 × 10 pts × multiplier 15 = 1500.
        // A score higher than lines × 1500 is impossible in the game.
        // Implies score == 0 when lines == 0.
        && d.score <= d.lines * 1500
        && d.createdAt == request.time; // forces serverTimestamp()
    }
  }
}
